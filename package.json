{
  "name": "apartment-complaint-system",
  "version": "2.0.0",
  "description": "Smart Apartment Complaint & Management System - Enterprise Edition",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed-demo-data.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:api": "jest --testPathPattern=api.test.js",
    "test:load": "artillery run load-test.yml",
    "lint": "eslint .",
    "docker:build": "docker build -t apartment-system .",
    "docker:run": "docker run -p 5000:5000 apartment-system",
    "deploy:docker": "docker-compose up -d"
  },
  "keywords": ["apartment", "complaint", "management", "enterprise"],
  "author": "Development Team",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "dotenv": "^16.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "multer": "^1.4.4",
    "nodemailer": "^6.8.0",
    "pdfkit": "^0.12.3",
    "redis": "^4.3.1",
    "helmet": "^6.0.0",
    "express-rate-limit": "^6.6.0",
    "joi": "^17.9.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "artillery": "^1.7.9",
    "eslint": "^8.37.0"
  }
}
